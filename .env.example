# ──────────────────────────────────────────────────────────────────────────
# Pinheiro OS — Configuração
# ──────────────────────────────────────────────────────────────────────────

# Porta do servidor (Coolify mapeia pro subdomínio)
PORT=4000

# ── PostgreSQL ────────────────────────────────────────────────────────────
# Mesmo servidor PG do Maxxi, DATABASE diferente (`pinheiro_os`).
# O nome do banco pode ser sobrescrito por DATABASE_URL_PINHEIRO.
DATABASE_URL=postgres://user:senha@host:5432/maxxi_db
# DATABASE_URL_PINHEIRO=postgres://user:senha@host:5432/pinheiro_os

# ── Admin inicial ─────────────────────────────────────────────────────────
# Senha padrão pro primeiro login (TROCAR depois!)
PINHEIRO_ADMIN_SENHA=admin123

# ── Sync com Maxxi (puxa tickets do tipo técnico + instalação) ────────────
# URL da API v1 pública do Maxxi
MAXXI_API_URL=https://citmax.com.br/api/v1
# API key com escopo "read" — gere no painel admin do Maxxi
MAXXI_API_KEY=
# Intervalo do sync em ms (default 30s)
MAXXI_SYNC_INTERVAL_MS=30000

# ── Sync com SGP (opcional — direto no PG do SGP) ─────────────────────────
SGP_DB_HOST=177.52.37.37
SGP_DB_NAME=dbctirn
SGP_DB_USER=consulta_ctirn
SGP_DB_PASS=

# ── IA (Whisper para transcrição de voz) ──────────────────────────────────
OPENAI_API_KEY=

# ── Web Push (VAPID) — gere com: npx web-push generate-vapid-keys ─────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tecnico@pinheiro.app

# ── TomTom (rotas + mapas) ────────────────────────────────────────────────
TOMTOM_KEY=5jW3vl4d6DeADyg089hZP8PtzERtXaiM
